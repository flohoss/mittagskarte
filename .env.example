# App config
TZ=Europe/Berlin

# Application metadata (synced to PocketBase Settings.Meta on startup)
APP_NAME=Mittagskarte
APP_URL=https://your-domain.tld

# SMTP (required in production, synced to PocketBase Settings.SMTP on startup)
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SENDER_NAME=Mittagskarte
SMTP_SENDER_ADDRESS=noreply@your-domain.tld

# Initial superuser (created/updated on startup, then unset from environment)
SUPERUSER_EMAIL=
SUPERUSER_PASSWORD=
